{
  "compilerOptions": {
    "target": "ES2015",
    "module": "Node16",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "downlevelIteration": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "tests/**/*", "vite-env.d.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
