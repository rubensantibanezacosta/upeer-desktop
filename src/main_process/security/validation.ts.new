export * from './validationShared.js';
export * from './validationMessaging.js';
export * from './validationDht.js';
export * from './validationFiles.js';
export * from './validationVaultGroups.js';

import {
    validateAck,
    validateChat,
    validateChatClear,
    validateChatContact,
    validateChatDelete,
    validateChatReaction,
    validateChatUpdate,
    validateDrReset,
    validateHandshakeAccept,
    validateHandshakeReq,
    validateIdentityUpdate,
    validatePingPong,
    validateRead,
    validateTyping,
} from './validationMessaging.js';
import {
    validateDhtExchange,
    validateDhtFindNode,
    validateDhtFindValue,
    validateDhtFoundNodes,
    validateDhtFoundValue,
    validateDhtPing,
    validateDhtPong,
    validateDhtQuery,
    validateDhtResponse,
    validateDhtStore,
    validateDhtStoreAck,
    validateDhtUpdate,
    validateSyncPulse,
} from './validationDht.js';
import {
    validateFileAccept,
    validateFileCancel,
    validateFileChunk,
    validateFileChunkAck,
    validateFileDoneAck,
    validateFileProposal,
} from './validationFiles.js';
import {
    validateGroupAck,
    validateGroupInvite,
    validateGroupLeave,
    validateGroupMsg,
    validateGroupUpdate,
    validateReputationDeliver,
    validateReputationGossip,
    validateReputationRequest,
    validateVaultAck,
    validateVaultDelivery,
    validateVaultQuery,
    validateVaultRenew,
    validateVaultStore,
} from './validationVaultGroups.js';
import type { ValidationResult } from './validationShared.js';

const VALIDATORS: Record<string, (data: any) => ValidationResult> = {
    HANDSHAKE_REQ: validateHandshakeReq,
    HANDSHAKE_ACCEPT: validateHandshakeAccept,
    CHAT: validateChat,
    ACK: validateAck,
    READ: validateRead,
    TYPING: validateTyping,
    PING: validatePingPong,
    PONG: validatePingPong,
    CHAT_CONTACT: validateChatContact,
    CHAT_REACTION: validateChatReaction,
    CHAT_UPDATE: validateChatUpdate,
    CHAT_DELETE: validateChatDelete,
    CHAT_CLEAR_ALL: validateChatClear,
    DHT_QUERY: validateDhtQuery,
    DHT_RESPONSE: validateDhtResponse,
    DHT_UPDATE: validateDhtUpdate,
    DHT_EXCHANGE: validateDhtExchange,
    DHT_FIND_NODE: validateDhtFindNode,
    DHT_FIND_VALUE: validateDhtFindValue,
    DHT_STORE: validateDhtStore,
    DHT_STORE_ACK: validateDhtStoreAck,
    DHT_FOUND_NODES: validateDhtFoundNodes,
    DHT_FOUND_VALUE: validateDhtFoundValue,
    DHT_PING: validateDhtPing,
    DHT_PONG: validateDhtPong,
    SYNC_PULSE: validateSyncPulse,
    IDENTITY_UPDATE: validateIdentityUpdate,
    FILE_PROPOSAL: validateFileProposal,
    FILE_START: validateFileProposal,
    FILE_ACCEPT: validateFileAccept,
    FILE_CHUNK: validateFileChunk,
    FILE_CHUNK_ACK: validateFileChunkAck,
    FILE_ACK: validateFileChunkAck,
    FILE_DONE: validateFileDoneAck,
    FILE_DONE_ACK: validateFileDoneAck,
    FILE_END: validateFileDoneAck,
    FILE_CANCEL: validateFileCancel,
    VAULT_STORE: validateVaultStore,
    VAULT_QUERY: validateVaultQuery,
    VAULT_ACK: validateVaultAck,
    VAULT_DELIVERY: validateVaultDelivery,
    VAULT_RENEW: validateVaultRenew,
    GROUP_MSG: validateGroupMsg,
    GROUP_ACK: validateGroupAck,
    GROUP_INVITE: validateGroupInvite,
    GROUP_UPDATE: validateGroupUpdate,
    GROUP_LEAVE: validateGroupLeave,
    REPUTATION_GOSSIP: validateReputationGossip,
    REPUTATION_REQUEST: validateReputationRequest,
    REPUTATION_DELIVER: validateReputationDeliver,
    DR_RESET: validateDrReset,
};

export function validateMessage(type: string, data: any): ValidationResult {
    const validator = VALIDATORS[type];
    if (!validator) {
        return { valid: false, error: `Unknown message type: ${type}` };
    }
    return validator(data);
}
